"""
Endophynd Snakemake workflow.

Phases:
  0  — scaffold (stub rules; emits placeholder .qza)
  1  — read-level discovery MVP (Logan unitigs, streaming)
  1.5 — calibration + mock community
  2  — multi-locus classification + HTML report
  ...

Run:
  snakemake --configfile workflow/config/params.yml --cores 4
  snakemake --configfile workflow/config/params.yml --cores 1 --dry-run
"""

import os
import sys
import csv
from pathlib import Path

configfile: "workflow/config/params.yml"


# ---------------------------------------------------------------------------
# Sample sheet
# ---------------------------------------------------------------------------

def load_samples(sheet_path):
    with open(sheet_path) as f:
        return list(csv.DictReader(f))

SAMPLES = load_samples(config["samplesheet"])
SAMPLE_IDS = [s["sample_id"] for s in SAMPLES]
SAMPLE_BY_ID = {s["sample_id"]: s for s in SAMPLES}


def _sample_field(wildcards, field, default=""):
    return SAMPLE_BY_ID.get(wildcards.sample, {}).get(field, default)


def _sample_source(wildcards):
    return _sample_field(wildcards, "source", "local")


def _sample_acc(wildcards):
    return _sample_field(wildcards, "accession", "")


def _sample_platform(wildcards):
    return _sample_field(wildcards, "platform", "illumina")


# ---------------------------------------------------------------------------
# Cache directories (resolved at runtime from cache.yml)
# ---------------------------------------------------------------------------

import yaml as _yaml

with open(config["cache_config"]) as _f:
    _cache = _yaml.safe_load(_f)

HOT = Path(os.path.expanduser(_cache["hot_dir"]))
COLD = Path(os.path.expanduser(_cache["cold_dir"]))
DB = Path(os.path.expanduser(_cache["db_dir"]))
HOT_CAP_GB = _cache["hot_cap_gb"]

# Results land on cold storage
RUN_ID = config.get("run_id") or "run_001"
RESULTS = COLD / "results" / RUN_ID


# ---------------------------------------------------------------------------
# Seed-file guard
# Warn if the placeholder seed set is in use; hard-fail if the file is
# missing entirely.  This check runs at DAG-build time so the user sees
# the warning before any rule executes.
# ---------------------------------------------------------------------------

_SEED_REF = Path(config["bait"]["seed_ref"])

if not _SEED_REF.exists():
    raise WorkflowError(
        f"\n\n[SEED FILE MISSING] {_SEED_REF} does not exist.\n"
        "Build it first:\n"
        "  python scripts/build_rrna_seeds.py --email your@email.com\n"
        "Or verify an existing file:\n"
        "  python scripts/build_rrna_seeds.py --verify\n"
    )

_SEED_IS_PLACEHOLDER = False
with open(_SEED_REF) as _sf:
    _first_line = _sf.readline()
    if "TESTING_PLACEHOLDER" in _first_line:
        _SEED_IS_PLACEHOLDER = True

if _SEED_IS_PLACEHOLDER:
    sys.stderr.write(
        "\n[WARNING] resources/rrna_seeds.fa is the TESTING PLACEHOLDER.\n"
        "  This is fine for Phase 0 smoke tests on fixtures.\n"
        "  Before Phase 1 (real Logan data), replace it:\n"
        "    python scripts/build_rrna_seeds.py --email your@email.com\n\n"
    )


# ---------------------------------------------------------------------------
# UNITE classifier guard
# The classify rule blasts ITS features against the UNITE BLAST DB (D30).
# Warn at DAG-build time so the user sees it before any rule executes (a missing
# DB does not block a --dry-run; it only fails the classify rule at run time).
# ---------------------------------------------------------------------------

_UNITE_DB = DB / config["classify"]["ITS"]["db"]
if not (_UNITE_DB.with_suffix(".nin").exists() or _UNITE_DB.with_suffix(".ndb").exists()):
    sys.stderr.write(
        f"\n[WARNING] UNITE BLAST DB not found at {_UNITE_DB}.*\n"
        "  The classify rule will fail. Build it once from the UNITE general FASTA:\n"
        "    scripts/build_unite_db.sh <unite_general_release.fasta>\n"
        "  (UNITE v10.0 Fungi: https://doi.org/10.15156/BIO/3301229)\n\n"
    )


# ---------------------------------------------------------------------------
# Final targets
# ---------------------------------------------------------------------------

rule all:
    input:
        expand(str(RESULTS / "{sample}" / "fungal_taxa_table.tsv"), sample=SAMPLE_IDS),
        str(RESULTS / "provenance.json"),


# ---------------------------------------------------------------------------
# Rule: triage
# Pre-flight checks before committing to streaming:
#   - Logan: verify accession looks like SRR/ERR/DRR (format only; size check deferred to Phase 1.5)
#   - local: verify the file exists
#   - SRA: verify accession looks like SRR/ERR/DRR (format only; no network call)
# ---------------------------------------------------------------------------

rule triage:
    input:
        sheet=config["samplesheet"],
    output:
        passed=HOT / "triage" / "{sample}.passed",
    params:
        source=lambda wildcards: _sample_source(wildcards),
        acc=lambda wildcards: _sample_acc(wildcards),
        platform=lambda wildcards: _sample_platform(wildcards),
    log:
        COLD / "logs" / "triage" / "{sample}.log",
    conda:
        "../envs/retrieve_bait.yml"
    shell:
        """
        mkdir -p $(dirname {output.passed})
        mkdir -p $(dirname {log})

        STAMP=$(date -u +%Y%m%dT%H%M%SZ)
        {{
            echo "=== [triage] {wildcards.sample}  $STAMP ==="
            echo "  source   : {params.source}"
            echo "  acc      : {params.acc}"
            echo "  platform : {params.platform}"
        }} > {log}

        SOURCE="{params.source}"
        ACC="{params.acc}"

        if [ "$SOURCE" = "logan" ]; then
            # Basic accession format check: SRR/ERR/DRR run accessions.
            # Does NOT download; size check from logan-pub/stat parquet deferred to Phase 1.5.
            if echo "$ACC" | grep -qE '^(SRR|ERR|DRR)[0-9]+$'; then
                echo "[triage] {wildcards.sample}: Logan $ACC format OK" | tee -a {log}
            else
                echo "[triage][WARN] {wildcards.sample}: '$ACC' doesn't look like a" \
                     "standard SRR/ERR/DRR accession — proceeding anyway" | tee -a {log}
            fi

        elif [ "$SOURCE" = "local" ]; then
            if [ -f "$ACC" ]; then
                echo "[triage] {wildcards.sample}: local file $ACC exists" | tee -a {log}
            else
                echo "[triage][ERROR] {wildcards.sample}: local file not found: $ACC" | tee -a {log}
                exit 1
            fi

        elif [ "$SOURCE" = "sra" ]; then
            # Validate accession format only — no network call.
            if echo "$ACC" | grep -qE '^(SRR|ERR|DRR)[0-9]+$'; then
                echo "[triage] {wildcards.sample}: SRA $ACC format OK" | tee -a {log}
            else
                echo "[triage][WARN] {wildcards.sample}: '$ACC' doesn't look like a" \
                     "standard SRR/ERR/DRR accession — proceeding anyway" | tee -a {log}
            fi

        else
            echo "[triage][ERROR] source='$SOURCE' not supported." \
                 "Use 'logan', 'local', or 'sra'." | tee -a {log}
            exit 1
        fi

        # Platform validation — warn on unknown values so users catch typos early.
        PLATFORM="{params.platform}"
        case "$PLATFORM" in
            illumina|pacbio-hifi|pacbio-clr|ont) ;;
            *)
                echo "[triage][WARN] {wildcards.sample}: platform='$PLATFORM'" \
                     "not in (illumina|pacbio-hifi|pacbio-clr|ont) —" \
                     "bait/quality settings will default to illumina" | tee -a {log}
                ;;
        esac

        echo "triage_ok source=$SOURCE acc=$ACC platform=$PLATFORM" > {output.passed}
        """


# ---------------------------------------------------------------------------
# Rule: retrieve_and_bait
# Stream input → k-mer bait → write candidate rDNA reads only.
#
# Logan path:
#   aws s3 cp s3://logan-pub/u/<ACC>/<ACC>.unitigs.fa.zst - --no-sign-request
#     | zstdcat
#     | bbduk.sh in=stdin.fa ref=<seeds> outm=<baited.fa> k=31 hdist=1
#
# SRA path:
#   fasterq-dump <ACC> --stdout --split-spot --skip-technical
#     | bbduk.sh in=stdin.fq ref=<seeds> outm=<baited.fa> k=31 hdist=1
#
# Both paths: the raw data is NEVER written to disk — only the small baited
# output lands on the hot cache.  bbduk writes match statistics to
# bait_stats.txt so discard rate is tracked as a QC metric.
#
# Local path (fixtures / pre-downloaded files):
#   bbduk.sh in=<file> ref=<seeds> outm=<baited.fa> ...
# ---------------------------------------------------------------------------

rule retrieve_and_bait:
    input:
        passed=HOT / "triage" / "{sample}.passed",
    output:
        baited=HOT / "baited" / "{sample}.baited.fa",
        bait_stats=HOT / "baited" / "{sample}.bait_stats.txt",
    params:
        source=lambda wildcards: _sample_source(wildcards),
        acc=lambda wildcards: _sample_acc(wildcards),
        platform=lambda wildcards: _sample_platform(wildcards),
        seed_ref=config["bait"]["seed_ref"],
        k=config["bait"]["k"],
        hdist=config["bait"]["hdist"],
        minlength=config["bait"]["minlength"],
    threads: config.get("bait_threads", 4)
    log:
        COLD / "logs" / "bait" / "{sample}.log",
    conda:
        "../envs/retrieve_bait.yml"
    shell:
        """
        mkdir -p $(dirname {output.baited})
        mkdir -p $(dirname {log})

        STAMP=$(date -u +%Y%m%dT%H%M%SZ)
        {{
            echo "=== [bait] {wildcards.sample} START $STAMP ==="
            echo "  source    : {params.source}"
            echo "  acc       : {params.acc}"
            echo "  platform  : {params.platform}"
            echo "  seed_ref  : {params.seed_ref}"
            echo "  seed_md5  : $(md5sum {params.seed_ref} | cut -d' ' -f1)"
            echo "  k         : {params.k}"
            echo "  hdist     : {params.hdist}"
            echo "  minlength : {params.minlength}"
            echo "  threads   : {threads}"
            echo "  bbduk     : $(bbduk.sh --version 2>&1 | grep BBTools | head -1 || echo unknown)"
            echo ""
        }} >> {log}

        SOURCE="{params.source}"
        ACC="{params.acc}"

        if [ "$SOURCE" = "logan" ]; then
            # Stream compressed unitigs from Logan public S3 bucket.
            # --no-sign-request: public bucket, no AWS credentials needed.
            # Pipe chain: download → decompress → bait.  Nothing hits disk
            # except the small baited output.
            {{
                aws s3 cp \
                    "s3://logan-pub/u/${{ACC}}/${{ACC}}.unitigs.fa.zst" \
                    - \
                    --no-sign-request \
                | zstdcat \
                | bbduk.sh \
                    in=stdin.fa \
                    ref={params.seed_ref} \
                    outm={output.baited} \
                    stats={output.bait_stats} \
                    k={params.k} \
                    hdist={params.hdist} \
                    minlength={params.minlength} \
                    threads={threads}
            }} 2>> {log}

        elif [ "$SOURCE" = "local" ]; then
            bbduk.sh \
                in="$ACC" \
                ref={params.seed_ref} \
                outm={output.baited} \
                stats={output.bait_stats} \
                k={params.k} \
                hdist={params.hdist} \
                minlength={params.minlength} \
                threads={threads} \
                2>> {log}

        elif [ "$SOURCE" = "sra" ]; then
            PLATFORM="{params.platform}"

            # Per-platform streaming and bait settings.
            # Illumina (PE): --split-spot interleaves R1/R2; int=t tells bbduk
            #   to treat pairs together (bait-then-mate: keep both reads if either
            #   matches). minlength=100; no quality floor (Illumina Q30+ inherently).
            # PacBio HiFi (CCS): single-end long reads, Q30-40. No split-spot.
            #   minlength=500 to skip adapter fragments; minavgquality=30.
            # PacBio CLR / ONT: single-end, error-prone (Q10-20). No split-spot.
            #   minlength=500; minavgquality=15. Classification capped at genus in
            #   provenance — do not report species-level calls from these platforms.
            # Retrieval is always: prefetch the .sra, then stream it LOCALLY with
            # fastq-dump (legacy) piped to bbduk.
            #   WHY NOT `fasterq-dump --stdout`: it hangs from remote (sra-tools
            #   2.11.3) and its local mode needs ~3x-the-.sra scratch (D30). fastq-dump
            #   streams spot-by-spot with negligible scratch.
            #   WHY int=f / threads=4: bbduk's multithreaded stdin FASTQ reader
            #   misaligns records ("missing plus" crash) at higher threads / int=t;
            #   the single-stream parser is robust (D30). We bait reads individually.
            if [ "$PLATFORM" = "illumina" ]; then
                BAIT_MINLEN={params.minlength}
                QUAL_ARG=""
            elif [ "$PLATFORM" = "pacbio-hifi" ]; then
                BAIT_MINLEN=500
                QUAL_ARG="minavgquality=30"
            elif [ "$PLATFORM" = "pacbio-clr" ] || [ "$PLATFORM" = "ont" ]; then
                BAIT_MINLEN=500
                QUAL_ARG="minavgquality=15"
            else
                echo "[bait][WARN] {wildcards.sample}: unknown platform '$PLATFORM'" \
                     "— defaulting to illumina settings" >> {log}
                BAIT_MINLEN={params.minlength}
                QUAL_ARG=""
            fi

            SRATMP={HOT}/sra_tmp/{wildcards.sample}
            mkdir -p $SRATMP
            {{
                echo "  prefetch    : $(prefetch --version 2>&1 | head -1 || echo unknown)"
                echo "  fastq-dump  : $(fastq-dump --version 2>&1 | head -1 || echo unknown)"
                echo "  bait_minlen : $BAIT_MINLEN"
                echo "  bait_mode   : int=f threads=4 (stdin-safe)"
                echo ""
            }} >> {log}

            # 1) prefetch the .sra locally (deterministic; default size cap is 20G).
            prefetch "$ACC" --max-size 100g -O $SRATMP >> {log} 2>&1

            # 2) stream the local .sra through bbduk; bait single-end (int=f).
            {{
                fastq-dump --split-spot --skip-technical -Z "$SRATMP/$ACC/$ACC.sra" \
                | bbduk.sh \
                    in=stdin.fq \
                    int=f \
                    ref={params.seed_ref} \
                    outm={output.baited} \
                    stats={output.bait_stats} \
                    k={params.k} \
                    hdist={params.hdist} \
                    minlength=$BAIT_MINLEN \
                    $QUAL_ARG \
                    threads=4
            }} 2>> {log}

            # 3) delete the .sra (process-then-delete; never keep raw data).
            rm -rf $SRATMP

        else
            echo "[ERROR] source='$SOURCE' not supported." \
                 "Supported: logan, local, sra." >> {log}
            exit 1
        fi

        # Summarize bait results; the summary line is parsed by the provenance rule.
        NSEQ=$(grep -c "^>" {output.baited} 2>/dev/null || echo 0)
        TOTAL=$(awk '/^#Total/{{print $2}}' {output.bait_stats} 2>/dev/null || echo "?")
        MATCHED=$(awk '/^#Matched/{{print $2}}' {output.bait_stats} 2>/dev/null || echo "?")
        MATCH_PCT=$(awk '/^#Matched/{{print $3}}' {output.bait_stats} 2>/dev/null || echo "?")
        STAMP_END=$(date -u +%Y%m%dT%H%M%SZ)
        {{
            echo "[bait] {wildcards.sample}: total_reads=$TOTAL matched=$MATCHED ($MATCH_PCT) seqs_out=$NSEQ"
            echo "=== [bait] {wildcards.sample} END $STAMP_END ==="
        }} >> {log}
        if [ "$NSEQ" = "0" ]; then
            echo "[bait][WARN] {wildcards.sample}: 0 sequences baited — check seed file and accession." >> {log}
        fi
        """


# ---------------------------------------------------------------------------
# Rule: annotate_and_gate
# Run ITSx; measure informative length; emit pass/coarse/fine/discard labels.
# (Phase 0: stub — all reads pass as "fine")
# ---------------------------------------------------------------------------

rule annotate_and_gate:
    input:
        baited=HOT / "baited" / "{sample}.baited.fa",
    output:
        gated=HOT / "gated" / "{sample}.gated.fa",
        gate_report=HOT / "gated" / "{sample}.gate_report.tsv",
    threads: config["itsx"]["cpu"]
    log:
        COLD / "logs" / "gate" / "{sample}.log",
    conda:
        "../envs/annotate.yml"
    shell:
        """
        mkdir -p $(dirname {output.gated})
        mkdir -p $(dirname {log})

        NBAITED=$(grep -c '^>' {input.baited} 2>/dev/null || echo 0)
        echo "[gate] {wildcards.sample}: ITSx ITS extraction on $NBAITED baited reads" > {log}

        PREFIX={HOT}/gated/{wildcards.sample}.itsx
        DEREP={HOT}/gated/{wildcards.sample}.prederep.fa

        # Pre-derep identical baited reads (high-copy rDNA reads are very redundant)
        # so ITSx does less work, then extract ITS1/ITS2.  ITSx anchors on the
        # conserved SSU/5.8S/LSU flanks and emits ONLY the variable spacers — removing
        # the conserved 5.8S is what lets blastn-vs-UNITE (classify) separate fungal
        # ITS from host-plant ITS (D30).  -t F,T scans Fungi + plants; --partial 50
        # keeps partial ITS from short WGS reads that cross a single anchor.
        vsearch --derep_fulllength {input.baited} --sizeout --minseqlength 80 \
            --output $DEREP --threads {threads} 2>> {log} || cp {input.baited} $DEREP

        ITSx -i $DEREP -o $PREFIX \
            -t F,T --save_regions all --partial 50 --minlen 50 \
            --heuristics T --preserve T --multi_thread T --cpu {threads} \
            >> {log} 2>&1 || echo "[gate][WARN] {wildcards.sample}: ITSx returned non-zero" >> {log}

        # Combine ITS1 + ITS2 -> the gated ITS feature set for classification.
        # Redirect always creates the output even if ITSx found nothing (|| true keeps
        # bash strict-mode happy when the region files are absent).
        cat ${{PREFIX}}.ITS1.fasta ${{PREFIX}}.ITS2.fasta 2>/dev/null > {output.gated} || true
        [ -f {output.gated} ] || : > {output.gated}

        {{
            printf "region\tn_seqs\n"
            for R in ITS1 ITS2 5_8S SSU LSU; do
                N=$(grep -c '^>' ${{PREFIX}}.$R.fasta 2>/dev/null || true); N=${{N:-0}}
                printf "%s\t%s\n" "$R" "$N"
            done
        }} > {output.gate_report}

        rm -f $DEREP ${{PREFIX}}.* 2>/dev/null || true
        NPASSED=$(grep -c '^>' {output.gated} 2>/dev/null || echo 0)
        echo "[gate] {wildcards.sample}: $NPASSED ITS regions (ITS1+ITS2) extracted" >> {log}
        """


# ---------------------------------------------------------------------------
# Rule: dereplicate
# vsearch dereplication → features + frequencies.
# (Phase 0: stub — one feature per input)
# ---------------------------------------------------------------------------

rule dereplicate:
    input:
        gated=HOT / "gated" / "{sample}.gated.fa",
    output:
        features=HOT / "features" / "{sample}.features.fa",
        counts=HOT / "features" / "{sample}.counts.tsv",
    log:
        COLD / "logs" / "derep" / "{sample}.log",
    conda:
        "../envs/annotate.yml"
    shell:
        """
        mkdir -p $(dirname {output.features})
        mkdir -p $(dirname {log})

        NIN=$(grep -c '^>' {input.gated} 2>/dev/null || echo 0)
        echo "[derep] {wildcards.sample}: dereplicating $NIN ITS regions" > {log}

        if [ "$NIN" = "0" ]; then
            # No ITS recovered: emit empty features + header-only counts so the DAG
            # completes honestly (classify will report 0 fungal).
            : > {output.features}
            printf "feature_id\tsize\n" > {output.counts}
            echo "[derep] {wildcards.sample}: 0 ITS regions — empty feature set" >> {log}
        else
            # Collapse identical ITS spacers across reads; clean labels (raw read
            # headers contain spaces that break parsers) + abundance (= # reads
            # supporting each unique ITS).
            vsearch --derep_fulllength {input.gated} \
                --relabel {wildcards.sample}_its --sizeout --minseqlength 50 \
                --output {output.features} 2>> {log}
            printf "feature_id\tsize\n" > {output.counts}
            grep '^>' {output.features} \
                | sed -E 's/^>([^;]+);size=([0-9]+).*/\\1\t\\2/' >> {output.counts}
            NU=$(grep -c '^>' {output.features} 2>/dev/null || echo 0)
            echo "[derep] {wildcards.sample}: $NU unique ITS features" >> {log}
        fi
        """


# ---------------------------------------------------------------------------
# Rule: classify
# q2-feature-classifier against UNITE/SILVA; emit taxonomy TSV.
# (Phase 0: stub — "k__Fungi;unclassified")
# ---------------------------------------------------------------------------

rule classify:
    input:
        features=HOT / "features" / "{sample}.features.fa",
    output:
        taxonomy=RESULTS / "{sample}" / "taxonomy.tsv",
    params:
        db=str(DB / config["classify"]["ITS"]["db"]),
        min_identity=config["classify"]["ITS"].get("min_identity", 90),
        min_qcov=config["classify"]["ITS"].get("min_qcov", 60),
    threads: config.get("classify_threads", 4)
    log:
        COLD / "logs" / "classify" / "{sample}.log",
    conda:
        "../envs/annotate.yml"
    shell:
        """
        mkdir -p $(dirname {output.taxonomy})
        mkdir -p $(dirname {log})
        NF=$(grep -c '^>' {input.features} 2>/dev/null || echo 0)
        echo "[classify] {wildcards.sample}: blastn-vs-UNITE on $NF ITS features" > {log}
        echo "  db        : {params.db}" >> {log}
        echo "  thresholds: >={params.min_identity}% id, >={params.min_qcov}% qcov" >> {log}

        if [ "$NF" = "0" ]; then
            printf "feature_id\tsize\tfungal\ttaxon\tpct_identity\taln_len\tunite_subject\n" \
                > {output.taxonomy}
            echo "[classify] {wildcards.sample}: 0 features — empty taxonomy" >> {log}
        else
            # Validated discriminator (D30): a feature is fungal iff it blasts to
            # UNITE at >=id / >=qcov over the ITSx-extracted ITS (5.8S already removed).
            python scripts/classify_its_blast.py \
                --features {input.features} \
                --db {params.db} \
                --out {output.taxonomy} \
                --min-identity {params.min_identity} \
                --min-qcov {params.min_qcov} \
                --threads {threads} 2>> {log}
        fi
        """


# ---------------------------------------------------------------------------
# Rule: build_feature_table
# Aggregate per-feature ITS taxonomy into a per-accession fungal taxa table
# (genus-level, abundance-weighted). A QIIME2 FeatureTable[.qza] export can be
# layered on later; the TSV is the immediate "what fungi are here" deliverable.
# ---------------------------------------------------------------------------

rule build_feature_table:
    input:
        taxonomy=RESULTS / "{sample}" / "taxonomy.tsv",
    output:
        table=RESULTS / "{sample}" / "fungal_taxa_table.tsv",
    params:
        min_its=config.get("recovery", {}).get("min_its_features", 10),
    log:
        COLD / "logs" / "table" / "{sample}.log",
    conda:
        "../envs/annotate.yml"
    shell:
        """
        mkdir -p $(dirname {output.table})
        mkdir -p $(dirname {log})
        # Per-accession answer to "what fungi are here": confident fungal ITS features
        # grouped by genus, weighted by read support. Emits a recovery_ok flag so an
        # apparent taxon-absence can be distinguished from a failed/low-yield run.
        python scripts/aggregate_taxa.py \
            --taxonomy {input.taxonomy} \
            --out {output.table} \
            --min-its {params.min_its} 2>> {log}
        echo "[table] {wildcards.sample}: fungal taxa table written" >> {log}
        """


# ---------------------------------------------------------------------------
# Rule: cleanup_transient
# Delete per-accession hot-cache files after classification.
# Triggered automatically when delete_transient_after_classify is true.
# ---------------------------------------------------------------------------

if config.get("delete_transient_after_classify", True):
    rule cleanup_transient:
        input:
            table=RESULTS / "{sample}" / "fungal_taxa_table.tsv",
        output:
            touch(HOT / "cleaned" / "{sample}.cleaned"),
        shell:
            """
            mkdir -p $(dirname {output[0]})
            rm -rf {HOT}/sra_tmp/{wildcards.sample}
            rm -f {HOT}/baited/{wildcards.sample}.baited.fa \
                  {HOT}/baited/{wildcards.sample}.bait_stats.txt \
                  {HOT}/gated/{wildcards.sample}.gated.fa \
                  {HOT}/gated/{wildcards.sample}.gate_report.tsv \
                  {HOT}/features/{wildcards.sample}.features.fa \
                  {HOT}/features/{wildcards.sample}.counts.tsv
            """


# ---------------------------------------------------------------------------
# Rule: provenance
# Write provenance.json for the run.
# ---------------------------------------------------------------------------

rule provenance:
    input:
        tables=expand(
            str(RESULTS / "{sample}" / "fungal_taxa_table.tsv"),
            sample=SAMPLE_IDS,
        ),
        bait_logs=expand(
            str(COLD / "logs" / "bait" / "{sample}.log"),
            sample=SAMPLE_IDS,
        ),
    output:
        prov=RESULTS / "provenance.json",
    run:
        import json, datetime, subprocess, hashlib, re

        def git_sha():
            try:
                return subprocess.check_output(
                    ["git", "rev-parse", "HEAD"], text=True
                ).strip()
            except Exception:
                return "unknown"

        def git_branch():
            try:
                return subprocess.check_output(
                    ["git", "rev-parse", "--abbrev-ref", "HEAD"], text=True
                ).strip()
            except Exception:
                return "unknown"

        def md5_file(path):
            h = hashlib.md5()
            try:
                with open(path, "rb") as fh:
                    for chunk in iter(lambda: fh.read(65536), b""):
                        h.update(chunk)
                return h.hexdigest()
            except Exception:
                return "missing"

        def parse_bait_log(log_path):
            try:
                text = Path(str(log_path)).read_text()
                m = re.search(
                    r'\[bait\]\s+\S+:\s+total_reads=(\S+)\s+matched=(\S+)\s+\((\S+)\)\s+seqs_out=(\S+)',
                    text,
                )
                if m:
                    return {
                        "total_reads": m.group(1),
                        "matched": m.group(2),
                        "match_pct": m.group(3),
                        "seqs_out": m.group(4),
                    }
            except Exception:
                pass
            return {"total_reads": "?", "matched": "?", "match_pct": "?", "seqs_out": "?"}

        def tool_version(cmd):
            try:
                return subprocess.check_output(
                    cmd, stderr=subprocess.STDOUT, text=True
                ).strip().splitlines()[0]
            except Exception:
                return "unknown"

        seed_ref = config["bait"]["seed_ref"]
        its_primers = "resources/its_primers.fa"

        bait_stats = {
            sid: parse_bait_log(log_path)
            for sid, log_path in zip(SAMPLE_IDS, input.bait_logs)
        }

        prov = {
            "run_id": RUN_ID,
            "timestamp": datetime.datetime.utcnow().isoformat() + "Z",
            "git_commit": git_sha(),
            "git_branch": git_branch(),
            "seed_checksums": {
                seed_ref: md5_file(seed_ref),
                its_primers: md5_file(its_primers),
            },
            "tool_versions": {
                "snakemake": tool_version(["snakemake", "--version"]),
                "python": tool_version(["python3", "--version"]),
            },
            "samples": SAMPLE_IDS,
            "bait_stats": bait_stats,
            "phase": "discovery-A-validated (D30)",
            "note": (
                "Discovery pipeline (D30): retrieve (prefetch+fastq-dump, SRA) / "
                "stream Logan -> bbduk bait -> vsearch derep -> ITSx ITS1/ITS2 -> "
                "vsearch derep -> blastn-vs-UNITE classify (>=90% id / >=60% qcov is "
                "the fungal discriminator) -> per-genus fungal taxa table. Requires the "
                "UNITE blastn DB at <db_dir>/unite/ (build with scripts/build_unite_db.sh)."
            ),
            "params": config,
        }
        os.makedirs(str(RESULTS), exist_ok=True)
        with open(str(output.prov), "w") as f:
            json.dump(prov, f, indent=2)
