"""
Endophynd Snakemake workflow.

Phases:
  0  — scaffold (stub rules; emits placeholder .qza)
  1  — read-level discovery MVP (Logan unitigs, streaming)
  1.5 — calibration + mock community
  2  — multi-locus classification + HTML report
  ...

Run:
  snakemake --configfile workflow/config/params.yml --cores 4
  snakemake --configfile workflow/config/params.yml --cores 1 --dry-run
"""

import os
import sys
import csv
from pathlib import Path

configfile: "workflow/config/params.yml"


# ---------------------------------------------------------------------------
# Sample sheet
# ---------------------------------------------------------------------------

def load_samples(sheet_path):
    with open(sheet_path) as f:
        return list(csv.DictReader(f))

SAMPLES = load_samples(config["samplesheet"])
SAMPLE_IDS = [s["sample_id"] for s in SAMPLES]
SAMPLE_BY_ID = {s["sample_id"]: s for s in SAMPLES}


def _sample_field(wildcards, field, default=""):
    return SAMPLE_BY_ID.get(wildcards.sample, {}).get(field, default)


def _sample_source(wildcards):
    return _sample_field(wildcards, "source", "local")


def _sample_acc(wildcards):
    return _sample_field(wildcards, "accession", "")


# ---------------------------------------------------------------------------
# Cache directories (resolved at runtime from cache.yml)
# ---------------------------------------------------------------------------

import yaml as _yaml

with open(config["cache_config"]) as _f:
    _cache = _yaml.safe_load(_f)

HOT = Path(os.path.expanduser(_cache["hot_dir"]))
COLD = Path(os.path.expanduser(_cache["cold_dir"]))
DB = Path(os.path.expanduser(_cache["db_dir"]))
HOT_CAP_GB = _cache["hot_cap_gb"]

# Results land on cold storage
RUN_ID = config.get("run_id") or "run_001"
RESULTS = COLD / "results" / RUN_ID


# ---------------------------------------------------------------------------
# Seed-file guard
# Warn if the placeholder seed set is in use; hard-fail if the file is
# missing entirely.  This check runs at DAG-build time so the user sees
# the warning before any rule executes.
# ---------------------------------------------------------------------------

_SEED_REF = Path(config["bait"]["seed_ref"])

if not _SEED_REF.exists():
    raise WorkflowError(
        f"\n\n[SEED FILE MISSING] {_SEED_REF} does not exist.\n"
        "Build it first:\n"
        "  python scripts/build_rrna_seeds.py --email your@email.com\n"
        "Or verify an existing file:\n"
        "  python scripts/build_rrna_seeds.py --verify\n"
    )

_SEED_IS_PLACEHOLDER = False
with open(_SEED_REF) as _sf:
    _first_line = _sf.readline()
    if "TESTING_PLACEHOLDER" in _first_line:
        _SEED_IS_PLACEHOLDER = True

if _SEED_IS_PLACEHOLDER:
    sys.stderr.write(
        "\n[WARNING] resources/rrna_seeds.fa is the TESTING PLACEHOLDER.\n"
        "  This is fine for Phase 0 smoke tests on fixtures.\n"
        "  Before Phase 1 (real Logan data), replace it:\n"
        "    python scripts/build_rrna_seeds.py --email your@email.com\n\n"
    )


# ---------------------------------------------------------------------------
# Final targets
# ---------------------------------------------------------------------------

rule all:
    input:
        expand(str(RESULTS / "{sample}" / "feature_table.stub.qza"), sample=SAMPLE_IDS),
        str(RESULTS / "provenance.json"),


# ---------------------------------------------------------------------------
# Rule: triage
# Pre-flight checks before committing to streaming:
#   - Logan: verify accession looks like GCA_XXXXXXXXXX (format only for now;
#     size check from logan-pub/stats parquet is deferred to Phase 1.5)
#   - local: verify the file exists
#   - SRA: not yet implemented
# ---------------------------------------------------------------------------

rule triage:
    input:
        sheet=config["samplesheet"],
    output:
        passed=HOT / "triage" / "{sample}.passed",
    params:
        source=lambda wildcards: _sample_source(wildcards),
        acc=lambda wildcards: _sample_acc(wildcards),
    log:
        COLD / "logs" / "triage" / "{sample}.log",
    conda:
        "envs/retrieve_bait.yml"
    shell:
        """
        mkdir -p $(dirname {output.passed})
        mkdir -p $(dirname {log})

        SOURCE="{params.source}"
        ACC="{params.acc}"

        if [ "$SOURCE" = "logan" ]; then
            # Basic accession format check (GCA_XXXXXXXXXX or similar).
            # Does NOT download; size check from parquet deferred to Phase 1.5.
            if echo "$ACC" | grep -qE '^(GCA|GCF)_[0-9]{{9}}\.[0-9]+$'; then
                echo "[triage] {wildcards.sample}: Logan $ACC format OK" | tee {log}
            else
                echo "[triage][WARN] {wildcards.sample}: '$ACC' doesn't look like a" \
                     "standard GCA/GCF accession — proceeding anyway" | tee {log}
            fi

        elif [ "$SOURCE" = "local" ]; then
            if [ -f "$ACC" ]; then
                echo "[triage] {wildcards.sample}: local file $ACC exists" | tee {log}
            else
                echo "[triage][ERROR] {wildcards.sample}: local file not found: $ACC" | tee {log}
                exit 1
            fi

        else
            echo "[triage][ERROR] source='$SOURCE' not supported." \
                 "Use 'logan' or 'local'." | tee {log}
            exit 1
        fi

        echo "triage_ok source=$SOURCE acc=$ACC" > {output.passed}
        """


# ---------------------------------------------------------------------------
# Rule: retrieve_and_bait
# Stream input → k-mer bait → write candidate rDNA reads only.
#
# Logan path (primary):
#   aws s3 cp s3://logan-pub/u/<ACC>/<ACC>.unitigs.fa.zst - --no-sign-request
#     | zstdcat
#     | bbduk.sh in=stdin.fa ref=<seeds> outm=<baited.fa> k=31 hdist=1
#
# The whole unitig file is NEVER written to disk — only the small baited
# output lands on the hot cache.  bbduk writes match statistics to
# bait_stats.txt so discard rate is tracked as a QC metric.
#
# Local path (fixtures / pre-downloaded files):
#   bbduk.sh in=<file> ref=<seeds> outm=<baited.fa> ...
#
# SRA path: Phase 3.
# ---------------------------------------------------------------------------

rule retrieve_and_bait:
    input:
        passed=HOT / "triage" / "{sample}.passed",
    output:
        baited=HOT / "baited" / "{sample}.baited.fa",
        bait_stats=HOT / "baited" / "{sample}.bait_stats.txt",
    params:
        source=lambda wildcards: _sample_source(wildcards),
        acc=lambda wildcards: _sample_acc(wildcards),
        seed_ref=config["bait"]["seed_ref"],
        k=config["bait"]["k"],
        hdist=config["bait"]["hdist"],
        minlength=config["bait"]["minlength"],
    threads: config.get("bait_threads", 4)
    log:
        COLD / "logs" / "bait" / "{sample}.log",
    conda:
        "envs/retrieve_bait.yml"
    shell:
        """
        mkdir -p $(dirname {output.baited})
        mkdir -p $(dirname {log})

        SOURCE="{params.source}"
        ACC="{params.acc}"

        if [ "$SOURCE" = "logan" ]; then
            # Stream compressed unitigs from Logan public S3 bucket.
            # --no-sign-request: public bucket, no AWS credentials needed.
            # Pipe chain: download → decompress → bait.  Nothing hits disk
            # except the small baited output.
            {{
                aws s3 cp \
                    "s3://logan-pub/u/${{ACC}}/${{ACC}}.unitigs.fa.zst" \
                    - \
                    --no-sign-request \
                | zstdcat \
                | bbduk.sh \
                    in=stdin.fa \
                    ref={params.seed_ref} \
                    outm={output.baited} \
                    stats={output.bait_stats} \
                    k={params.k} \
                    hdist={params.hdist} \
                    minlength={params.minlength} \
                    threads={threads}
            }} 2>> {log}

        elif [ "$SOURCE" = "local" ]; then
            bbduk.sh \
                in="$ACC" \
                ref={params.seed_ref} \
                outm={output.baited} \
                stats={output.bait_stats} \
                k={params.k} \
                hdist={params.hdist} \
                minlength={params.minlength} \
                threads={threads} \
                2>> {log}

        else
            echo "[ERROR] source='$SOURCE' not yet implemented." \
                 "Supported: logan, local. SRA support in Phase 3." >> {log}
            exit 1
        fi

        # Warn (but don't fail) if bbduk found nothing — could be a real
        # absence of rDNA, or a seed-set miss.  Gate stats log the rate.
        NSEQ=$(grep -c "^>" {output.baited} 2>/dev/null || echo 0)
        echo "[bait] {wildcards.sample}: $NSEQ candidate sequences baited" >> {log}
        if [ "$NSEQ" = "0" ]; then
            echo "[bait][WARN] {wildcards.sample}: 0 sequences baited — check" \
                 "seed file and accession." >> {log}
        fi
        """


# ---------------------------------------------------------------------------
# Rule: annotate_and_gate
# Run ITSx; measure informative length; emit pass/coarse/fine/discard labels.
# (Phase 0: stub — all reads pass as "fine")
# ---------------------------------------------------------------------------

rule annotate_and_gate:
    input:
        baited=HOT / "baited" / "{sample}.baited.fa",
    output:
        gated=HOT / "gated" / "{sample}.gated.fa",
        gate_report=HOT / "gated" / "{sample}.gate_report.tsv",
    log:
        COLD / "logs" / "gate" / "{sample}.log",
    conda:
        "envs/annotate.yml"
    shell:
        """
        mkdir -p $(dirname {output.gated})
        # Phase 0 stub: pass everything through.
        cp {input.baited} {output.gated}
        printf "read_id\tlocus\tinformative_bp\tgate_decision\n" > {output.gate_report}
        echo "[gate] {wildcards.sample}: stub (all reads passed as fine)" > {log}
        """


# ---------------------------------------------------------------------------
# Rule: dereplicate
# vsearch dereplication → features + frequencies.
# (Phase 0: stub — one feature per input)
# ---------------------------------------------------------------------------

rule dereplicate:
    input:
        gated=HOT / "gated" / "{sample}.gated.fa",
    output:
        features=HOT / "features" / "{sample}.features.fa",
        counts=HOT / "features" / "{sample}.counts.tsv",
    log:
        COLD / "logs" / "derep" / "{sample}.log",
    conda:
        "envs/annotate.yml"
    shell:
        """
        mkdir -p $(dirname {output.features})
        # Phase 0 stub: treat entire baited file as one feature.
        cp {input.gated} {output.features}
        printf "feature_id\t{wildcards.sample}\n" > {output.counts}
        printf "feat_001\t1\n" >> {output.counts}
        echo "[derep] {wildcards.sample}: stub" > {log}
        """


# ---------------------------------------------------------------------------
# Rule: classify
# q2-feature-classifier against UNITE/SILVA; emit taxonomy TSV.
# (Phase 0: stub — "k__Fungi;unclassified")
# ---------------------------------------------------------------------------

rule classify:
    input:
        features=HOT / "features" / "{sample}.features.fa",
    output:
        taxonomy=RESULTS / "{sample}" / "taxonomy.tsv",
    log:
        COLD / "logs" / "classify" / "{sample}.log",
    conda:
        "envs/classify.yml"
    shell:
        """
        mkdir -p $(dirname {output.taxonomy})
        printf "Feature ID\tTaxon\tConfidence\tlocus\tinformative_bp\trecovery_path\n" \
            > {output.taxonomy}
        printf "feat_001\tk__Fungi;unclassified\t0.0\tITS1\t0\tread_stub\n" \
            >> {output.taxonomy}
        echo "[classify] {wildcards.sample}: stub" > {log}
        """


# ---------------------------------------------------------------------------
# Rule: build_feature_table
# Assemble QIIME2 .qza FeatureTable[Frequency] from counts + taxonomy.
# (Phase 0: stub .qza — a zip with a placeholder artifact)
# ---------------------------------------------------------------------------

rule build_feature_table:
    input:
        counts=HOT / "features" / "{sample}.counts.tsv",
        taxonomy=RESULTS / "{sample}" / "taxonomy.tsv",
    output:
        qza=RESULTS / "{sample}" / "feature_table.stub.qza",
    log:
        COLD / "logs" / "table" / "{sample}.log",
    conda:
        "envs/classify.yml"
    shell:
        """
        mkdir -p $(dirname {output.qza})
        # Phase 0: write a placeholder zip so Snakemake considers the rule satisfied.
        # Phase 1 will replace this with real BIOM construction + qiime tools import.
        echo "STUB_QZA sample={wildcards.sample}" | zip - > {output.qza} 2>/dev/null || \
            printf "STUB_QZA sample={wildcards.sample}" > {output.qza}
        echo "[table] {wildcards.sample}: stub .qza written" > {log}
        """


# ---------------------------------------------------------------------------
# Rule: cleanup_transient
# Delete per-accession hot-cache files after classification.
# Triggered automatically when delete_transient_after_classify is true.
# ---------------------------------------------------------------------------

if config.get("delete_transient_after_classify", True):
    rule cleanup_transient:
        input:
            qza=RESULTS / "{sample}" / "feature_table.stub.qza",
        output:
            touch(HOT / "cleaned" / "{sample}.cleaned"),
        shell:
            """
            mkdir -p $(dirname {output[0]})
            rm -f {HOT}/baited/{wildcards.sample}.baited.fa \
                  {HOT}/baited/{wildcards.sample}.bait_stats.txt \
                  {HOT}/gated/{wildcards.sample}.gated.fa \
                  {HOT}/gated/{wildcards.sample}.gate_report.tsv \
                  {HOT}/features/{wildcards.sample}.features.fa \
                  {HOT}/features/{wildcards.sample}.counts.tsv
            """


# ---------------------------------------------------------------------------
# Rule: provenance
# Write provenance.json for the run.
# ---------------------------------------------------------------------------

rule provenance:
    input:
        qzas=expand(
            str(RESULTS / "{sample}" / "feature_table.stub.qza"),
            sample=SAMPLE_IDS,
        ),
    output:
        prov=RESULTS / "provenance.json",
    run:
        import json, datetime, subprocess

        def git_sha():
            try:
                return subprocess.check_output(
                    ["git", "rev-parse", "HEAD"], text=True
                ).strip()
            except Exception:
                return "unknown"

        prov = {
            "run_id": RUN_ID,
            "timestamp": datetime.datetime.utcnow().isoformat() + "Z",
            "git_commit": git_sha(),
            "samples": SAMPLE_IDS,
            "phase": "1-read-level-discovery",
            "note": (
                "Phase 1: real Logan streaming + bbduk baiting. "
                "Annotation, dereplication, and classification are still stubs "
                "(Phase 2). Taxonomy results are placeholders only."
            ),
            "params": config,
        }
        os.makedirs(str(RESULTS), exist_ok=True)
        with open(str(output.prov), "w") as f:
            json.dump(prov, f, indent=2)
